generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversion {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title     String   @db.VarChar(255)
  userId    String   @db.VarChar(255)
  jobId     String   @db.VarChar(255)
  createdAt DateTime @default(now())

  @@map("conversions")
}

model Job {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String   @db.VarChar(255)
  status       JobStatus
  pdfUrl       String   @db.VarChar(255)
  outputUrl    String?  @db.VarChar(255)
  errorMessage String?  @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("jobs")
}

model UserRole {
  id     String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId String @unique @db.VarChar(255)
  role   UserRoleType

  @@map("user_roles")
}

model UserSubscription {
  id             String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String @unique @db.VarChar(255) @map("user_id")
  customerId     String @db.VarChar(255) @map("customer_id")
  planId         String @db.VarChar(255) @map("plan_id")
  status         String @db.VarChar(50) @map("status")
  subscriptionId String @db.VarChar(255) @map("subscription_id")

  @@map("user_subscriptions")
}

model UserTokenBalance {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @unique @db.VarChar(255) @map("user_id")
  balance   Int
  onhold    Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_token_balances")
}


enum JobStatus {
  pending
  in_progress
  completed
  failed
}

enum UserRoleType {
  admin
  user
}